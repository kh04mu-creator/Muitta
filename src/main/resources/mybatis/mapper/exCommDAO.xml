<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="com.springboot.project.dao.exCommDAO">
	<select id="exclistDao" resultType="com.springboot.project.dto.exCommDTO">
		select * from ex_comm order by exc_no desc
	</select>
	<select id="exc_viewDao" resultType="com.springboot.project.dto.exCommDTO">
		select * from ex_comm where exc_no=#{param1}
	</select>
	<insert id="exc_writeDao">
		insert into ex_comm values(ex_comm_seq.nextval, #{exc_writer}, SYSDATE, #{exc_detail}, #{ex_no})
	</insert>
	<update id="exc_updateDao">
		update ex_comm set exc_date=SYSDATE, exc_detail=#{exc_detail} where exc_no=#{exc_no}
	</update>
	<delete id="exc_deleteDao">
		delete from ex_comm where exc_no=#{param1}
	</delete>
</mapper>
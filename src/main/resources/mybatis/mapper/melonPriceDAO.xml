<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springboot.project.dao.melonPriceDAO">
	<select id="melon_listDao" resultType="com.springboot.project.dto.melonPriceDTO">
		select * from melon_price
	</select>
	<select id="melon_viewDao" resultType="com.springboot.project.dto.melonPriceDTO">
		select * from melon_price where melon_no=#{param1}
	</select>
	<insert id="melon_writeDao">
		insert into melon_price values(melon_price_seq.nextval, #{melon_title}, #{melon_price},#{melon_link}, #{mu_no})
	</insert>
	<update id="melon_updateDao">
		update melon_price set melon_title=#{melon_title}, melon_price=#{melon_price}, melon_link=#{melon_link} where mu_no=#{mu_no}
	</update>
	<delete id="melon_deleteDao">
		delete from melon_price where melon_no=#{param1}
	</delete>
</mapper>
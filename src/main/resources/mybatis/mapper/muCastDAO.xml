<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springboot.project.dao.muCastDAO">
	<select id="mucast_listDao" resultType="com.springboot.project.dto.muCastDTO">
		select * from mu_cast
	</select>
	<select id="mucast_viewDao" resultType="com.springboot.project.dto.muCastDTO">
		select * from mu_cast where ca_no=#{param1}
	</select>
	<insert id="mucast_writeDao">
		insert into mu_cast values(mu_cast_seq, #{ca_pname}, #{ca_role}, #{ca_name}, #{mi_no})
	</insert>
	<update id="mucast_updateDao">
		update mu_cast set ca_pname=#{ca_pname}, ca_role=#{ca_role}, ca_name=#{ca_name} where ca_no=#{ca_no}
	</update>
	<delete id="mucast_deleteDao">
		delete from mu_cast where ca_no=#{param1}
	</delete>
</mapper>
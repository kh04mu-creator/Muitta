<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="com.springboot.project.dao.muInfoDAO">
	<select id="melon_listDao" resultType="com.springboot.project.dto.muInfoDTO">
		select * from mu_info
	</select>
	<select id="melon_viewDao" resultType="com.springboot.project.dto.muInfoDTO">
		select * from mu_info where melon_no=#{param1}
	</select>
	<insert id="melon_writeDao">
		insert into mu_info values(mi_no_seq.nextval, #{mi_detail}, #{mi_upload},#{mi_pname}, #{mu_no})
	</insert>
	<update id="melon_updateDao">
		update mu_info set mi_detail=#{mi_detail}, mi_upload=#{mi_upload}, mi_pname=#{mi_pname} where mi_no=#{mi_no}
	</update>
	<delete id="melon_deleteDao">
		delete from mu_info where mi_no=#{param1}
	</delete>
</mapper>
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.springboot.project.dao.interPriceDAO">
	<select id="inter_listDao" resultType="com.springboot.project.dto.interPriceDTO">
		select * from inter_price
	</select>
	<select id="inter_viewDao" resultType="com.springboot.project.dto.interPriceDTO">
		select * from inter_price where inter_no=#{param1}
	</select>
	<insert id="inter_writeDao">
		insert into inter_price values(inter_price_seq.nextval, #{inter_title}, #{inter_price}, #{inter_link}, #{mu_no})
	</insert>
	<update id="inter_updateDao">
		update inter_price set inter_title=#{inter_title}, inter_price=#{inter_price}, inter_link=#{inter_link} where inter_no=#{inter_no}
	</update>
	<delete id="inter_deleteDao">
		delete from inter_price where inter_no=#{param1}
	</delete>
</mapper>
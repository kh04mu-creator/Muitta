<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.project.dao.rwLikeDAO">
	<select id="rw_listDao" resultType="com.springboot.project.dto.rwLikeDTO">
		select * from rwLike order by rw_no desc	 	
	</select>
	<select id="rw_viewDao" resultType="com.springboot.project.dto.rwLikeDTO">
		select * from rwLike where rw_no=#{param1} 	
	</select>

	<update id="rw_updateDao"> 	
         update rwLike set // 공감 취소 where rw_no=#{rw_no}
	</update> 
	<delete id="rw_deleteDao">
		delete from rwLike where rw_no=#{param1}
	</delete>
	</mapper>
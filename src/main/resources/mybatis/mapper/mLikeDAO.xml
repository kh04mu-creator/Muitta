<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper 
	PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
	"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springboot.project.dao.mLikeDAO">
	<select id="l_listDao" resultType="com.springboot.project.dto.mLikeDTO">
		select * from m_like order by l_no desc	 	
	</select>
	<select id="l_viewDao" resultType="com.springboot.project.dto.mLikeDTO">
		select * from m_like where l_no=#{param1} 	
	</select>
	<select id="l_countDao" resultType="com.springboot.project.dto.mLikeDTO">
		select count(*) from m_like where mu_no=#{param1} 	
	</select>
	<insert id="l_writeDao">
		insert into m_like
		 values(m_like_seq.nextval,#{l_title},#{l_start},#{l_end},#{mu_no},#{m_no})
	</insert>
	<delete id="l_deleteDao">
		delete from m_like where l_no=#{param1}
	</delete>
	</mapper>
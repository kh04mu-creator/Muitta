<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC " //mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
 
<mapper namespace="com.springboot.project.dao.yesPriceDAO">
	<select id="yes_listDao" resultType="com.springboot.project.dto.yesPriceDTO">
		select * from yes_price
	</select>
	<select id="yes_writeDao" resultType="com.springboot.project.dto.yesPriceDTO">
		select * from yes_price where yes_no=#{param1}
	</select>
	<insert id="yes_writeDao">
		insert into yes_price values(yes_price_seq.nextval, #{yes_title}, #{yes_price},#{yes_link}, #{yes_no})
	</insert>
	<update id="yes_updateDao">
		update yes_price set yes_title=#{yes_title}, yes_price=#{yes_price}, yes_link=#{yes_link} where mu_no=#{mu_no}
	</update>
	<delete id="yes_deleteDao">
		delete from yes_price where yes_no=#{param1}
	</delete>
</mapper>